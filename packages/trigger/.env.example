# Database
DATABASE_URL=

# Trigger.dev
TRIGGER_SECRET_KEY=

# GCP KMS - Used to decrypt Shopify access tokens and other credentials
# Must match the same KMS key used by the API to encrypt
# GCP_SERVICE_ACCOUNT_JSON should be base64-encoded: cat service-account.json | base64
GCP_KMS_PROJECT_ID=
GCP_KMS_LOCATION=
GCP_KMS_KEY_RING=
GCP_KMS_KEY=
GCP_SERVICE_ACCOUNT_JSON=
